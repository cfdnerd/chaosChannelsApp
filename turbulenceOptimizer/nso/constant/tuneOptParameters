FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convergenceControl
{
    optMinIterations             50;
    optStallWindow               5;
    optObjectiveTol              1e-3;
    optConstraintTol             1e-3;
    optStepTol                   5e-3;
    optPowerConstraintWeight     1.0;
    optVolumeConstraintWeight    1.0;
}

adaptiveHeavisideProjection      no;   // Adaptive Heaviside beta continuation
enableTbBcSmoothingMode          no;   // Activate tbBcSmoothingMode field
normalizeScenarioObjectives      yes;   // Normalize MeanT/PDCon using first valid iteration

turbulenceOptimization
{
    useTurbulentResistance            no;  // Extra nut-based resistance scaling in alpha
    useFrozenTurbulenceAdjointTransport yes; // Only supported adjoint transport mode; 'no' aborts
    enableNonFiniteMetricStop         yes; // Stop on non-finite MeanT/PDCon/MaxT
}

stallRecoveryControl
{
    continuationConstraintViolationSoftTol  2e-2; // Above freeze tol, scale continuation instead of fully freezing
    continuationProgressMin                 0.2;  // Minimum alpha/q hardening fraction retained under stress
    grayStallContinuationBlendMin           0.1;  // Floor on continuation blend during gray-stall recovery
    projectionConstraintViolationSoftTol    2e-2; // Mild-stress band for continued beta sharpening
    projectionBetaGrowthFactorMin           1.02; // Minimum multiplicative beta growth under stress
    projectionUnstableGrowthScale           0.25; // Reduce beta growth when objective/step stability is weak
    grayStallThreshold                      0.85; // Gray fraction threshold that activates stall monitoring
    grayStallObjectiveTol                   5e-5; // Objective stagnation threshold for gray-stall detection
    grayStallStepTol                        2e-3; // Design-step threshold for gray-stall detection
    grayStallWindow                         8;    // Consecutive stalled iterations before forced sharpening
    grayStallBetaGrowthFactor               1.10; // Forced beta growth factor when gray-stall recovery fires
}

