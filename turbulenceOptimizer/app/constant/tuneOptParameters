FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convergenceControl
{
    optMinIterations             50;
    optStallWindow               5;
    optObjectiveTol              1e-3;
    optConstraintTol             1e-3;
    optStepTol                   5e-3;
    optPowerConstraintWeight     1.0;
    optVolumeConstraintWeight    1.0;
}

adaptiveHeavisideProjection      no;   // Adaptive Heaviside beta continuation
enableTbBcSmoothingMode          yes;   // Activate tbBcSmoothingMode field

turbulenceOptimization
{
    turbulenceProMode            no;   // Turbulence pro stabilizers toggle
}

