FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convergenceControl
{
    optMinIterations             50;
    optStallWindow               5;
    optObjectiveTol              1e-3;
    optConstraintTol             1e-3;
    optStepTol                   5e-3;
    optPowerConstraintWeight     1.0;
    optVolumeConstraintWeight    1.0;
}

adaptiveHeavisideProjection      no;   // Adaptive Heaviside beta continuation
enableTbBcSmoothingMode          yes;  // Activate tbBcSmoothingMode field
normalizeScenarioObjectives      no;   // Normalize MeanT/PDCon using first valid iteration

turbulenceOptimization
{
    useTurbulentResistance            yes; // Extra nut-based resistance scaling in alpha
    useFrozenTurbulenceAdjointTransport yes; // Only supported adjoint transport mode; 'no' aborts
    enableNonFiniteMetricStop         yes; // Stop on non-finite MeanT/PDCon/MaxT
    turbulenceResistanceFactor        0.35; // Discourage many tiny high-nut branches
    turbulenceResistanceCap           25;   // Limit extra resistance from extreme local nut spikes
    turbulenceStatePenaltyFactor      1.0;  // Global multiplier for turbulence-based resistance
}

continuationControl
{
    powerConstraintTighteningStartIteration 250;  // Start steering toward the hard pumping limit after topology forms
    powerConstraintTighteningRate           0.02; // Tighten PowerDissRelax toward PowerDissMax across late iterations
    filterRStart                            4.5;  // Begin with thicker, smoother channels
    filterREnd                              3.5;  // Retain a larger minimum length scale at the end
    filterRContinuationStart                1;    // Apply the filter schedule from the start
    filterRContinuationEnd                  250;  // Finish radius reduction before late-stage polishing
    projectionLowGrayFreezeStartIteration   450;  // Stop beta hardening once the design is already crisp
    projectionLowGrayFreezeThreshold        0.18; // Freeze continuation after the gray fraction is low enough
    projectionLowGrayFreezeObjectiveTol     2e-4; // Require real objective stagnation before freezing beta
    projectionLowGrayFreezeStepTol          5e-4; // Freeze only when the bulk design step is already small
    projectionLowGrayFreezeMinBeta          40;   // Ensure the design is sufficiently projected before freezing
}

thermalStabilization
{
    enableThermalMatrixRelaxation           yes;  // Use fvSolution relaxation on the primal thermal system
    enableAdjointThermalMatrixRelaxation    yes;  // Use fvSolution relaxation on the adjoint thermal system
    thermalUnderRelaxation                  0.85; // Blend new T with previous T to damp late-iteration thermal noise
    adjointThermalUnderRelaxation           0.65; // Stronger damping on Tb because it remains noisier late in the run
    thermalDiffusivityRelaxation            0.6;  // Lag DTeff to suppress noise from residual nut/epsilon motion
}

stallRecoveryControl
{
    continuationConstraintViolationSoftTol  2e-2; // Above freeze tol, scale continuation instead of fully freezing
    continuationProgressMin                 0.2;  // Minimum alpha/q hardening fraction retained under stress
    grayStallContinuationBlendMin           0.1;  // Floor on continuation blend during gray-stall recovery
    projectionConstraintViolationSoftTol    2e-2; // Mild-stress band for continued beta sharpening
    projectionBetaGrowthFactorMin           1.02; // Minimum multiplicative beta growth under stress
    projectionUnstableGrowthScale           0.25; // Reduce beta growth when objective/step stability is weak
    grayStallThreshold                      0.85; // Gray fraction threshold that activates stall monitoring
    grayStallObjectiveTol                   5e-5; // Objective stagnation threshold for gray-stall detection
    grayStallStepTol                        2e-3; // Design-step threshold for gray-stall detection
    grayStallWindow                         8;    // Consecutive stalled iterations before forced sharpening
    grayStallBetaGrowthFactor               1.10; // Forced beta growth factor when gray-stall recovery fires
}

