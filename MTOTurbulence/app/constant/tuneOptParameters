FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Optimizer stopping controls.
// The optimizer exits early only after the design step, objective drift,
// and constraint violation all remain small for several consecutive loops.
convergenceControl
{
    optPowerConstraintWeight 5.0;

    optMinIterations 200;
    optStallWindow 15;
    optObjectiveTol 1e-4;
    optConstraintTol 1e-3;
    optStepTol 1e-4;
}

